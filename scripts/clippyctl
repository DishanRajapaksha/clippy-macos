#!/bin/zsh
set -euo pipefail

usage() {
    local status="${1:-64}"
    cat >&2 <<'EOF'
Usage:
  clippyctl show
  clippyctl say TEXT...
  clippyctl animate [ANIMATION...]
  clippyctl agent AGENT...
EOF
    exit "$status"
}

urlencode() {
    /usr/bin/osascript -l JavaScript \
        -e 'function run(argv) { return encodeURIComponent(argv[0]); }' \
        -- "$1"
}

(( $# > 0 )) || usage
command="$1"
shift

case "$command" in
    show)
        (( $# == 0 )) || usage
        url='clippy://show'
        ;;
    say)
        (( $# > 0 )) || usage
        url="clippy://say?text=$(urlencode "$*")"
        ;;
    animate)
        if (( $# == 0 )); then
            url='clippy://animate'
        else
            url="clippy://animate?name=$(urlencode "$*")"
        fi
        ;;
    agent)
        (( $# > 0 )) || usage
        url="clippy://agent?name=$(urlencode "$*")"
        ;;
    -h|--help|help)
        usage 0
        ;;
    *)
        print -u2 "clippyctl: unknown command: $command"
        usage
        ;;
esac

/usr/bin/open "$url"
